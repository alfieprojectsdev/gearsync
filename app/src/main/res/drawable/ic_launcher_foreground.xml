<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive icon foreground: ascending segmented VU bars (lug-cyan → optimal-green
     → shift-red), mirroring the app's horizontal segmented meter and reading as
     climbing revs toward an upshift. Round stroke caps = the meter's rounded
     segments. Drawn inside the 108 viewport center safe zone (~22–86). Brand
     colors match res/values/colors.xml (vu_lug/opt/shift_segment). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Lug zone (cyan) — two shortest bars. -->
    <path android:strokeColor="#00D4FF" android:strokeWidth="8"
          android:strokeLineCap="round" android:pathData="M32,78 L32,66" />
    <path android:strokeColor="#00D4FF" android:strokeWidth="8"
          android:strokeLineCap="round" android:pathData="M43.5,78 L43.5,57" />

    <!-- Optimal zone (green) — mid bars. -->
    <path android:strokeColor="#00E676" android:strokeWidth="8"
          android:strokeLineCap="round" android:pathData="M55,78 L55,48" />
    <path android:strokeColor="#00E676" android:strokeWidth="8"
          android:strokeLineCap="round" android:pathData="M66.5,78 L66.5,39" />

    <!-- Shift / redline zone (red) — tallest bar. -->
    <path android:strokeColor="#FF1744" android:strokeWidth="8"
          android:strokeLineCap="round" android:pathData="M78,78 L78,30" />
</vector>
